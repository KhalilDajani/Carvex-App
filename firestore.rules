rules_version = '2';

// NOTE: this replaces your console rules on deploy. It matches Carvex's actual
// access patterns (approved-car streaming, admin status changes, in-app
// notifications, and participant-only chats). Reconcile with any custom rules
// you already have before `firebase deploy --only firestore:rules`.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users can read each other's basic profile (so a buyer sees the seller's
    // name/phone). Each user writes only their own doc; admins may edit roles.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin();
    }

    // Cars: sellers create their own; owner or admin can edit/delete.
    match /cars/{carId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.sellerId == request.auth.uid;
      allow update, delete: if isSignedIn()
        && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    // Notifications: list is filtered client-side; any signed-in user can read,
    // create (broadcasts/approvals), and mark as read.
    match /notifications/{id} {
      allow read, create, update: if isSignedIn();
    }

    // Chats: only the two participants can see or post.
    // NOTE: read must allow the case where the doc does not exist yet
    // (resource == null), otherwise getOrCreateChat's initial .get() is denied
    // and a new conversation can never be started.
    match /chats/{chatId} {
      allow read: if isSignedIn()
        && (resource == null
            || request.auth.uid in resource.data.participants);
      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        allow read: if isSignedIn()
          && request.auth.uid in
             get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn()
          && request.auth.uid == request.resource.data.senderId
          && request.auth.uid in
             get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    // Inquiries (the "Request Info" sheet). Buyers create their own; the
    // listing's seller and admins can read them.
    match /inquiries/{id} {
      allow create: if isSignedIn()
        && request.resource.data.buyerId == request.auth.uid;
      allow read, update: if isSignedIn()
        && (isAdmin() || resource.data.sellerId == request.auth.uid);
    }
  }
}
